%turbo-frame#modalPlaceholder
  .modal-content
    .modal-header
      Edit expense
      %button.btn-close{ :type => "button", "data-bs-dismiss" => "modal", "aria-label" => "Close" }
    .modal-body
      = render partial: "form", layout: false, locals: { expense: expense, statements: statements, categories: categories, async: async }
